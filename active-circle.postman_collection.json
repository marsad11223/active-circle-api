									"pm.collectionVariables.set('token', res.accessToken) ",
									"",
									"pm.test(\"Response status code is 201\", function () {",
									"    pm.expect(pm.response.code).to.equal(201);",
									"});",
									"",
									"",
									"pm.test(\"Email is in a valid format\", function () {",
									"    const responseData = pm.response.json();",
									"    ",
									"    pm.expect(responseData).to.be.an('object');",
									"    pm.expect(responseData.data.email).to.match(/^[\\w-]+(\\.[\\w-]+)*@[\\w-]+(\\.[\\w-]+)*(\\.[a-z]{2,})$/, \"Email should be in a valid format\");",
									"});",
									"",
									"",
									"pm.test(\"Password should not be empty\", function () {",
									"    const responseData = pm.response.json();",
									"",
									"    pm.expect(responseData).to.be.an('object');",
									"    pm.expect(responseData.data.password).to.exist.and.to.not.be.empty;",
									"});",
									"",
									"",
									"pm.test(\"Verify that the access token is being saved in the collection variables\", function () {",
									"    const responseData = pm.response.json();",
									"    ",
									"    console.log(responseData, 'responseData')",
									"    pm.expect(responseData).to.have.property('accessToken');",
									"    pm.expect(pm.collectionVariables.has('token')).to.be.true;",
									"});",
									""
								],
